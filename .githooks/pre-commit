#!/usr/bin/env bash
# Pre-commit hook: run static checks and unit tests before allowing a commit.
# Install with `make hooks-install`. Skip ad hoc with `git commit --no-verify`.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "pre-commit: go vet"
go vet ./...

echo "pre-commit: go test"
go test ./...

echo "pre-commit: ok"
